# Local development environment (§3.5). Copy to `.env` and fill in.
# `.env` is gitignored; never commit real connection strings or secrets.

# --- Neon Postgres (§3.1) ---
# On Vercel these are injected by the Neon integration. Locally, point them at the Neon
# `vercel-dev` BRANCH (not production), so local work never touches prod data.
# (`vercel-dev` is the integration's auto-created Development-env branch — §3.5.)
#   DATABASE_URL          = pooled connection  (host contains `-pooler`) — runtime queries
#   DATABASE_URL_UNPOOLED = direct connection  (no `-pooler`)            — migrations
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require"

# --- Health check (§3.7) ---
# Shared secret gating GET /api/health (sent as the `x-health-token` header).
# Generate one with: openssl rand -hex 32
HEALTH_CHECK_SECRET="replace-with-a-long-random-string"
