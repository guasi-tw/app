# Local development environment (§3.5). Copy to `.env` and fill in.
# `.env` is gitignored; never commit real connection strings or secrets.

# --- Neon Postgres (§3.1) ---
# On Vercel these are injected by the Neon integration. Locally, point them at the Neon
# `vercel-dev` BRANCH (not production), so local work never touches prod data.
# (`vercel-dev` is the integration's auto-created Development-env branch — §3.5.)
#   DATABASE_URL          = pooled connection  (host contains `-pooler`) — runtime queries
#   DATABASE_URL_UNPOOLED = direct connection  (no `-pooler`)            — migrations
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require"

# --- Health check (§3.7) ---
# Shared secret gating GET /api/health (sent as the `x-health-token` header).
# Generate one with: openssl rand -hex 32
HEALTH_CHECK_SECRET="replace-with-a-long-random-string"

# --- Auth.js site login (Google OAuth) — Milestone v0.6.0 ---
# AUTH_SECRET: generate with `openssl rand -hex 32`. Required in every environment.
# MUST be the SAME value in Production and Preview — the redirect proxy below verifies
# the OAuth `state` server-side with this secret, so a mismatch breaks preview login.
AUTH_SECRET="replace-with-a-long-random-string"
# Google OAuth client (Cloud Console → Credentials → Web application).
AUTH_GOOGLE_ID="replace-with-google-oauth-client-id"
AUTH_GOOGLE_SECRET="replace-with-google-oauth-client-secret"
# Production canonical URL (custom domain). Set per-environment in Vercel.
AUTH_URL="https://guasi.tw"
# Preview OAuth proxy: preview URLs are dynamic and can't be registered as Google
# redirect URIs, so callbacks proxy through production. Per Auth.js docs this MUST be
# set in BOTH the Preview AND the Production (stable) env — if it's missing on the
# stable env the proxy never activates and the prod callback fails with
# `InvalidCheck: pkceCodeVerifier could not be parsed`. (Leave unset in local dev.)
AUTH_REDIRECT_PROXY_URL="https://guasi.tw/api/auth"
